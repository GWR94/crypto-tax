# Copy to .env in this folder and paste your keys (never commit .env).



# Solana wallet import — Helius free key required (Solscan free cannot fetch wallets)

HELIUS_API_KEY=



# Optional — Solscan paid Lite+ only for wallet import; safe to leave blank

SOLSCAN_API_KEY=



# Ethereum + Arbitrum wallet import (same Etherscan API key)

ETHERSCAN_API_KEY=



# Cardano wallet import (optional — Koios works without a key)

BLOCKFROST_API_KEY=



# CoinGecko — live + historical USD prices (strongly recommended)

# Free Demo key: https://www.coingecko.com/en/api/pricing

# Without a key the public API rate-limits quickly (HTTP 429) and LTC/VET etc.

# fall back to cost-basis pricing even though CoinGecko lists them.

COINGECKO_API_KEY=

# Set to "pro" only if you have a paid CoinGecko Commercial API key

COINGECKO_API_PLAN=demo

